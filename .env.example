# Kopyala: cp .env.example .env  — .env git'e GİRMEZ (.gitignore)
# Rehber: docs/cuzdan-kurulum.md

# ---- Mod ----
# paper = sanal dolum (varsayılan) | live = gerçek işlem
BOT_MODE=paper

# ---- Phantom (varsayılan) — SOL paritesi, sunucuda key YOK ----
# 1 = panel Phantom ile imza; SOLANA_PRIVATE_KEY yok sayılır
PHANTOM_TRADING=1

# ---- Eski sunucu imzası (opsiyonel, PHANTOM_TRADING=0 gerekir) ----
# SOLANA_PRIVATE_KEY=
# EVM_PRIVATE_KEY=

# ---- İzleme (read-only, key gerekmez) ----
# Ana MetaMask adresin — sadece bakiye görüntüleme
WATCH_EVM_ADDRESS=
WATCH_SOLANA_ADDRESS=

# ---- RPC (ücretsiz) ----
# Public Solana RPC (Helius artık ücretli). QuickNode/Chainstack free tier veya:
# SOLANA_RPC_URL= · SOLANA_RPC_FALLBACK_URLS= (virgülle yedek)
# Daha iyi EVM limit: Alchemy free tier
SOLANA_RPC_URL=
SOLANA_RPC_FALLBACK_URLS=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
BSC_RPC_URL=

# ---- Karar eşikleri (Faz 8) ----
# Paper öneri: ENTRY_SCORE_MIN=55 · MIN_EDGE_AFTER_COST_PCT=3
# Demo: SMART_MONEY_REQUIRED=0 (prod'da 1 + ALPHA_WALLETS veya Helius Faz 8b)
# Paper agresif giriş: PAPER_AGGRESSIVE=1 · CONFLUENCE_MIN=52
PAPER_AGGRESSIVE=1
ENTRY_SCORE_MIN=52
MIN_EDGE_AFTER_COST_PCT=3
SMART_MONEY_REQUIRED=0
PAIR_COOLDOWN_SEC=5400
# Her kapanış sonrası aynı token bekle (sn) — kârda kısa, zararda PAIR_COOLDOWN_SEC
PAIR_COOLDOWN_ANY_SEC=1800
# Founder: genç pump scratch genişletme + fast path
FOUNDER_FAST_PATH=1
FOUNDER_FAST_CONF_RELAX=8
FOUNDER_SCRATCH_RELAX=1
FOUNDER_SCRATCH_PCT=-5.5
FOUNDER_SCRATCH_MAX_AGE_HOURS=24
# Scratch v2 — geniş eşik + min hold (churn azaltma)
SCRATCH_MIN_SEC=90
SCRATCH_WARM_H1=10
SCRATCH_WARM_PCT=-6.0
SCRATCH_MOMENTUM_PCT=-7.0
SCRATCH_HIGH_SCORE_MIN=68
SCRATCH_HIGH_SCORE_GRACE_SEC=30
SCRATCH_FLASH_PCT=-10.0
RUNNER_SCRATCH_PCT=-7.0
RUNNER_SCRATCH_MIN_SEC=120
PUMP_FUN_SCRATCH_PCT=-9.0
PUMP_FUN_SCRATCH_MIN_SEC=180
THETA_FLOOR_PCT=-4.0
THETA_DEEP_SEC=600
CONFLUENCE_REQUIRED=1
CONFLUENCE_MIN=52
CONFLUENCE_MIN_LAYERS=2

# ---- Tarama / giriş ağları ----
# Varsayılan: yalnız Solana — EVM pozisyon açılmaz (FRAG tipi slot tıkanıklığı önlenir)
SCAN_CHAINS=solana
ENTRY_CHAINS=solana
# Merkezi kilit: piyasa verisi yalnız Solana'dan çekilir; SCAN_CHAINS/ENTRY_CHAINS
# override'ları yok sayılır, EVM ağlarına hiç istek gitmez. Geri açmak için: SOLANA_ONLY=0
SOLANA_ONLY=1

# ---- Alpha cüzdan (12 KOL) — $0: ALPHA_RPC_FALLBACK=1 ----
# Ücretli Helius (opsiyonel): setup-helius-alpha.sh <KEY>
ALPHA_RPC_FALLBACK=1
ALPHA_WALLETS_FILE=config/alpha_wallets.txt
HELIUS_API_KEY=
ALPHA_WALLETS=
# Public RPC rate limit — düşük tut (1–25, öneri 5)
ALPHA_WALLET_SCAN_LIMIT=5

# ---- Risk limitleri ----
# $100 paper test önerisi: PAPER_START_BALANCE_USD=100 · MAX_POSITION_USD=15 · DAILY_LOSS_LIMIT_USD=15
PAPER_START_BALANCE_USD=100
MAX_POSITION_USD=15
DAILY_LOSS_LIMIT_USD=15
MAX_SLIPPAGE_BPS=100

# Paper modda gerçek DEX fiyatı + Jupiter çıkış teklifi (imza yok)
PAPER_LIVE_QUOTES=1

# ---- Slot rotation (max dolu → zayıfı bırak, güçlüye geç) ----
SLOT_ROTATION=1
ROTATION_MIN_SCORE_GAP=12
ROTATION_MIN_CONFLUENCE=55

# ---- CloddsBot fikir transferi (2026-06-17) — yüksek-x keşif ----
PUMP_FUN_FEED=1
PUMP_FUN_GENESIS_BONUS=15
PUMP_FUN_SCRATCH_PCT=-8.0
PUMP_FUN_SCRATCH_MIN_SEC=180
COPY_TRADE_ENABLED=1
COPY_TRADE_WINDOW_SEC=300
COPY_TRADE_MIN_WALLETS=2
HOLDER_RISK_ENABLED=1
GENESIS_TOP1_HOLDER_MAX_PCT=55
TOP1_HOLDER_MAX_PCT=45
JITO_EXIT=1
# JUPITER_PRIORITY_FEE=1
# JITO_TIP_LAMPORTS=

HIBRIT_BRAIN_ENABLED=1
# Paper giriş: Saito risk_off giriş cezasını sıfırla (çıkış rejimi kalır)
PAPER_BRAIN_PENALTY_MAX=0
HIBRIT_BRAIN_AUTO=0

# ---- 0x Swap API (EVM canlı — ücretsiz key: 0x.org) ----
ZEROX_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
